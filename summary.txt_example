[package]
name = "oreuit"
version = "0.1.0"
edition = "2021"
authors = ["Name"]
rust-version = "1.70"

[dependencies]
clap = { version = "4.1", features = ["derive"] }
walkdir = "2.3"
encoding_rs = "0.8"
arboard = { version = "3.4.1", optional = true }
lazy_static = "1.4.0"
serde = { version = "1", features = ["derive"] }
toml = "0.8"

[features]
default = []
clipboard = ["dep:arboard"]


